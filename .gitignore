# ── Secrets / local config ────────────────────────────────────────────────────
# Service-level .env files (with credentials) are ignored here and in each
# service's own .gitignore.
# The shared varTrack/.env (LOG_LEVEL, APP_ENV, CONFIG_PATH) is intentionally
# committed and whitelisted via the negation rule below.
.envrc
*.local.env
*.local.cue
**/.env
# Root config.cue holds live credentials — never commit it.
/config.cue

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
pip-log.txt
pip-delete-this-directory.txt

# ── buf (protobuf tooling) ────────────────────────────────────────────────────
buf.exe

