# Example config file — .env format.
# VarTrack parses KEY=VALUE pairs and writes each to the configured sink.
# Lines starting with # are comments and are ignored.

APP_NAME=my-service
APP_VERSION=1.0.0
APP_ENV=production
LOG_LEVEL=info
DEBUG=false

SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_WORKERS=4
SERVER_TIMEOUT=30

DB_HOST=prod-db.internal
DB_PORT=5432
DB_NAME=myapp
DB_USER=app-user
# @secret annotation — resolved from Vault at ETL time.
DB_PASSWORD=@secret(secret/myapp/db#password)
DB_POOL_SIZE=20
DB_SSL=true

REDIS_HOST=redis.internal
REDIS_PORT=6379
REDIS_DB=0

JWT_ALGORITHM=HS256
JWT_EXPIRY=86400
JWT_SECRET=@secret(secret/myapp/auth#jwt_secret)

FEATURE_NEW_UI=true
FEATURE_BETA_API=false
