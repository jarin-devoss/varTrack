# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.
#
#   cp .env.example .env

# ── Config ────────────────────────────────────────────────────────────────────

# Path to your config.cue bundle (relative to this file)
CONFIG_PATH=./config.cue

# "production" enables mTLS between services; "development" is permissive
APP_ENV=production

# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Credentials for the bundled MongoDB container.
# If you connect to an external MongoDB, remove the mongo service from
# docker-compose.yml and set the connection string directly in config.cue.

MONGO_ROOT_USER=vartrack
MONGO_ROOT_PASSWORD=change-me

# ── Ports ─────────────────────────────────────────────────────────────────────
# Change these if the defaults conflict with other services on your host.

# Webhook receiver — register this URL in GitHub / GitLab
# e.g. http://my-server:5657/webhooks/mongo
GATEWAY_PORT=5657

# Orchestrator HTTP API + OpenAPI docs at /docs
ORCHESTRATOR_PORT=8000

# ── Workers ───────────────────────────────────────────────────────────────────

# Celery worker concurrency — set to the number of CPU cores available
WORKER_CONCURRENCY=4

# How often the watcher polls datasources for drift (e.g. 30s, 2m, 5m)
WATCHER_POLL_INTERVAL=60s

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Set to your frontend origin if you access the orchestrator API from a browser.
# Leave empty to disable CORS headers.
CORS_ORIGINS=
